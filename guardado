from tkinter import *
from tkinter import messagebox
 
branco = '#ffffff'
azul = '#364a85'
vermelho = '#b53128'
amarelo = '#ffef08'
 
tela1 = Tk()
tela1.title('Agenda')
tela1.geometry('380x500+500+100')
tela1.wm_resizable(width=False, height=False)

def adicionar():
    f = open("dados.txt", "a", encoding="utf-8")
    f.write(input_nome.get())
    f.write(input_tel.get() + "\n")
    f.write(input_end.get() + "\n")
    f.write(input_dist.get() + "\n")
    f.write(input_pais.get() + "\n")
    f.write(input_email.get() + "\n")
    f.write("--------------------\n")
    f.close()

def pesquisar():
    with open("dados.txt", "r", encoding="utf-8") as ficheiro:
        for i in ficheiro:
            if input_nome.get() in i:
                print(i)



lb_agenda = Label(tela1, text='Sharkcoders Python', font='Time 20 bold', bg=amarelo, fg=vermelho, anchor='w', padx=10)
lb_agenda.place(width=380, height=50, x=0, y=0)
 
lb_nome = Label(tela1, text='Nome', font='Time 10', anchor='w')
