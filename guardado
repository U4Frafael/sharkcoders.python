btn_add = Button(tela1, text="Adicionar", command=adicionar)
btn_add.place(x=30, y=340)

btn_add = Button(tela1, text="Pesquisar", command=pesquisar)
btn_add.place(x=270, y=340)

tela1.mainloop()
